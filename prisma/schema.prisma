generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(ulid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  nickname     String?
  realname     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index(createdAt)
}

enum FileStatus {
  PENDING
  ACTIVE
  DELETED
}

model File {
  id          String     @id @default(cuid())
  userId      String
  domain      String
  bucket      String
  key         String
  filename    String
  contentType String
  status      FileStatus @default(PENDING)
  uploadId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}
