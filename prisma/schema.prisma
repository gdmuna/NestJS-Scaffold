generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid(7)) @db.Uuid
  username     String     @unique
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  role         UserRole   @default(USER_DEFAULT)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bannedUntil  DateTime?
  bannedReason String?

  profile       UserProfile?
  statusHistory UserStatusHistory[]
  files         File[]
}

enum UserRole {
  ADMIN
  USER_DEFAULT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

model UserProfile {
  userId     String          @id @default(uuid(7)) @db.Uuid
  nickname   String?
  avatarId   String?         @db.Uuid
  bio        String?
  sex        UserProfileSex?
  sexVisible Boolean         @default(true)
  birthday   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user   User  @relation(fields: [userId], references: [id])
  avatar File? @relation(fields: [avatarId], references: [id])
}

enum UserProfileSex {
  MALE
  FEMALE
  OTHER // wtf???
}

model UserStatusHistory {
  id           String                 @id @default(uuid(7)) @db.Uuid
  userId       String                 @db.Uuid
  operatorType UserStatusOperatorType
  operatorId   String?
  fromStatus   UserStatus
  toStatus     UserStatus
  remark       String?
  createdAt    DateTime               @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

enum UserStatusOperatorType {
  SYSTEM
  MANUAL
}

model File {
  id          String         @id @default(uuid(7)) @db.Uuid
  userId      String         @db.Uuid
  domain      FileDomain
  visibility  FileVisibility
  bucket      String
  key         String
  filename    String
  contentType String
  status      FileStatus     @default(PENDING)
  createdAt   DateTime       @default(now())

  user          User          @relation(fields: [userId], references: [id])
  profileAvatar UserProfile[]

  @@index([userId])
  @@index([status, createdAt])
}

enum FileStatus {
  PENDING
  ACTIVE
  DELETED
}

enum FileDomain {
  AVATAR
  DOCUMENT
  VIDEO
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}
